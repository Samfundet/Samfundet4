# The file '.docker.env' is fetched by docker-compose.

SECRET_KEY=NOT_SET
DJANGO_SETTINGS_MODULE=root.settings
# PYTHONPATH=/Users/emil/my-projects/rekenett

# See root.constants.Environment
# ENV=production
ENV=development

# Flag to enable debugpy. (yes/no)
ENABLE_DEBUGPY=yes

# Automatically create local superuser
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=Django123
DJANGO_SUPERUSER_EMAIL=mg-web@samfundet.no
DJANGO_SUPERUSER_FIRST_NAME=Sanctus
DJANGO_SUPERUSER_LAST_NAME=Richardus
DJANGO_SUPERUSER_PHONE_NUMBER=12345678

DOMAIN=0.0.0.0

# Bypass authentication for testing purposes. Only applies when ENV==DEVELOPMENT. (yes/no)
BYPASS_AUTHENTICATION=...

# ======================== #
#         Email            #
# ======================== #

EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER= example@gmail.com
EMAIL_HOST_PASSWORD=...

# Github webhook secret.
WEBHOOK_SECRET=...
